#===============================================Scripts===============================================#
#SAVAGE
eventScripts:
  - type: STR_SAVAGE_WRECK_EVENT
    oneTimeRandomEvents:
      STR_TEST_EVENT: 100
    firstMonth: 3
    executionOdds: 70

  - type: STR_TEST_EVENT
    oneTimeRandomEvents:
      STR_TEST_EVENT: 100
    firstMonth: 1
    executionOdds: 40
  - type: STR_PIZZA_TIME_SCRIPT
    eventWeights:
      0:
        STR_PIZZA_TIME_EVENT: 100
    counterMin: 0
    counterMax: 6
    executionOdds: 50
    firstMonth: 0

  - type: STR_SC_34_NEWS
    eventWeights:
      0:
        STR_GNN_NEWS_001: 60
        STR_GNN_NEWS_002: 60
        STR_GNN_NEWS_003: 60
        STR_GNN_NEWS_004: 60
        STR_GNN_NEWS_005: 60
    researchTriggers:
       STR_WEAPON_SHOPPING: true
    executionOdds: 100
  - type: STR_TRAFFIC_TICKET
    eventWeights:
      0:
        STR_TRAFFIC_TICKET: 100
    firstMonth: 1
    executionOdds: 55

