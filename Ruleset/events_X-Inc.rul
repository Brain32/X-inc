#===============================================Events===============================================#


events:
  - name: STR_TEST_EVENT
    description: STR_TEST_EVENT_DESCRIPTION
    background: CITY2_BG.SCR
    everyMultiItemList:
      STR_LOOTBOX6: 4
    researchList: [STR_LOOTBOX6]
    music: HUNTER_CLUB
    points: 25
    timer: 10000
    timerRandom: 20000

